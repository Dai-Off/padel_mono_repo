@import '../../styles/theme.wxss';

.cp-root {
  min-height: 100vh;
  background-color: #0f0f0f;
}

.cp-list,
.cp-config {
  min-height: 100vh;
}

.cp-scroll {
  height: 100vh;
  box-sizing: border-box;
}

.cp-hint {
  padding: 24rpx 32rpx;
  font-size: 26rpx;
  color: #9ca3af;
}

.cp-center {
  padding: 80rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cp-pad {
  padding-top: 120rpx;
}

.cp-muted {
  color: #9ca3af;
  font-size: 28rpx;
}

.cp-err {
  color: #f87171;
  font-size: 26rpx;
  text-align: center;
}

.cp-err-mt {
  margin-top: 16rpx;
}

.cp-retry {
  margin-top: 24rpx;
  background-color: rgba(241, 143, 52, 0.2);
  color: #f18f34;
  font-size: 28rpx;
}

.cp-retry::after {
  border: none;
}

.cp-club {
  margin: 0 24rpx 32rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.08);
  background-color: rgba(255, 255, 255, 0.03);
}

.cp-club-img {
  width: 100%;
  height: 200rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.cp-club-img--ph {
  background-color: #1a1a1a;
}

.cp-club-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
}

.cp-club-loc {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 8rpx;
}

.cp-date-lbl {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #f18f34;
  margin-top: 20rpx;
  margin-bottom: 12rpx;
}

.cp-slots-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.cp-slot {
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  padding: 14rpx 20rpx;
  border-radius: 16rpx;
  background-color: rgba(241, 143, 52, 0.12);
  border: 1px solid rgba(241, 143, 52, 0.45);
  color: #f18f34;
  font-size: 24rpx;
  font-weight: 600;
}

.cp-slot::after {
  border: none;
}

.cp-slot-hover {
  opacity: 0.88;
}

.cp-config {
  padding: 32rpx;
}

.cp-config-card {
  padding: 32rpx;
  border-radius: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.08);
  background-color: rgba(255, 255, 255, 0.04);
}

.cp-config-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 24rpx;
}

.cp-config-line {
  display: block;
  font-size: 28rpx;
  color: #e5e7eb;
  margin-bottom: 8rpx;
}

.cp-config-price {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #f18f34;
  margin-bottom: 32rpx;
}

.cp-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.cp-row-lbl {
  font-size: 28rpx;
  color: #ffffff;
}

.cp-gender-btn {
  margin-bottom: 32rpx;
  background-color: rgba(255, 255, 255, 0.06);
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 16rpx;
}

.cp-gender-btn::after {
  border: none;
}

.cp-cta {
  background: linear-gradient(90deg, #f18f34, #ffa940);
  color: #ffffff;
  font-weight: 700;
  font-size: 30rpx;
  border-radius: 999rpx;
  margin-bottom: 20rpx;
}

.cp-cta::after {
  border: none;
}

.cp-back {
  background-color: transparent;
  color: #9ca3af;
  font-size: 28rpx;
}

.cp-back::after {
  border: none;
}
