.launch-root {
  min-height: 100vh;
  background-color: #0f0f0f;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.launch-spinner {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(241, 143, 52, 0.25);
  border-top-color: #f18f34;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.launch-text {
  margin-top: 32rpx;
  font-size: 32rpx;
  color: #9ca3af;
}
