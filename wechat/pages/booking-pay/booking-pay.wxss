@import '../../styles/theme.wxss';

.bp-root {
  min-height: 100vh;
  background-color: var(--auth-bg);
  padding: 40rpx;
  box-sizing: border-box;
}

.bp-card {
  padding: 40rpx;
  border-radius: 32rpx;
  background-color: #1a1a1a;
  border-width: 1px;
  border-style: solid;
  border-color: rgba(255, 255, 255, 0.1);
}

.bp-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 32rpx;
  display: block;
}

.bp-line {
  display: block;
  font-size: 28rpx;
  color: #ffffff;
  margin-bottom: 16rpx;
  line-height: 40rpx;
}

.bp-muted {
  color: #9ca3af;
}

.bp-divider {
  height: 1px;
  background-color: rgba(255, 255, 255, 0.08);
  margin: 32rpx 0;
}

.bp-amount {
  font-size: 44rpx;
  font-weight: 700;
  color: #f18f34;
  display: block;
  margin-bottom: 24rpx;
}

.bp-hint {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 36rpx;
}

.bp-pay-btn {
  margin-top: 48rpx;
  width: 100%;
  padding: 28rpx;
  border-radius: 32rpx;
  background-color: #f18f34;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
}

.bp-pay-btn::after {
  border: none;
}
