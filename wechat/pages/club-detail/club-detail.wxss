@import '../../styles/theme.wxss';

.cd-root {
  min-height: 100vh;
  background-color: #0f0f0f;
  padding-bottom: 48rpx;
}

.cd-tabs {
  display: flex;
  flex-direction: row;
  padding: 24rpx 24rpx 8rpx;
  gap: 16rpx;
}

.cd-tab {
  flex: 1;
  padding: 16rpx;
  border-radius: 16rpx;
  background-color: rgba(255, 255, 255, 0.06);
  color: #9ca3af;
  font-size: 26rpx;
  font-weight: 600;
  border: 1px solid rgba(255, 255, 255, 0.08);
  text-align: center;
}

.cd-tab::after {
  border: none;
}

.cd-tab--on {
  background-color: rgba(241, 143, 52, 0.18);
  border-color: rgba(241, 143, 52, 0.45);
  color: #f18f34;
}

.cd-partidos-scroll {
  max-height: 1200rpx;
  min-height: 400rpx;
}

.cd-body--flat {
  padding-bottom: 64rpx;
}

.cd-matches-hint {
  font-size: 26rpx;
  color: #6b7280;
  margin-top: 16rpx;
}

.cd-match-list {
  margin-top: 24rpx;
}

.cd-match-gap {
  margin-bottom: 24rpx;
}

.cd-hero-wrap {
  position: relative;
  height: 360rpx;
  width: 100%;
}

.cd-hero {
  width: 100%;
  height: 100%;
}

.cd-hero--ph {
  background-color: #1a1a1a;
}

.cd-hero-scrim {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 160rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.85), transparent);
}

.cd-hero-title {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 32rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}

.cd-body {
  padding: 32rpx;
}

.cd-section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.cd-address {
  font-size: 26rpx;
  color: #9ca3af;
  margin-bottom: 32rpx;
  line-height: 40rpx;
}

.cd-court {
  margin-bottom: 40rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  border-width: 1px;
  border-style: solid;
  border-color: rgba(255, 255, 255, 0.08);
  background-color: rgba(255, 255, 255, 0.03);
}

.cd-court-head {
  margin-bottom: 16rpx;
}

.cd-court-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

.cd-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.cd-tag {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background-color: rgba(255, 255, 255, 0.06);
  margin-right: 12rpx;
}

.cd-no-slots {
  font-size: 26rpx;
  color: #6b7280;
}

.cd-slots-scroll {
  width: 100%;
  white-space: nowrap;
}

.cd-slots-inner {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
}

.cd-slot-btn {
  display: inline-flex;
  margin-right: 16rpx;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  background-color: rgba(241, 143, 52, 0.12);
  border-width: 1px;
  border-style: solid;
  border-color: rgba(241, 143, 52, 0.45);
  color: #f18f34;
  font-size: 26rpx;
  font-weight: 600;
}

.cd-slot-btn::after {
  border: none;
}

.cd-slot-btn--hover {
  opacity: 0.85;
}

.cd-loading {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #0f0f0f;
}

.cd-loading-text {
  color: #9ca3af;
  font-size: 28rpx;
}
