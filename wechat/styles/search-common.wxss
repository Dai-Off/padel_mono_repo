@import './theme.wxss';

.search-root {
  height: 100vh;
  background-color: var(--search-bg);
  display: flex;
  flex-direction: column;
}

.search-sticky {
  background-color: rgba(15, 15, 15, 0.96);
  border-bottom-width: 1px;
  border-bottom-style: solid;
  border-bottom-color: rgba(255, 255, 255, 0.05);
  padding: 12rpx 32rpx 24rpx;
  box-sizing: border-box;
}

.search-top-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 24rpx;
}

.search-icon-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  background-color: rgba(255, 255, 255, 0.05);
  border-width: 1px;
  border-style: solid;
  border-color: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
}

.search-icon-btn::after {
  border: none;
}

.search-icon-btn-text {
  color: #ffffff;
  font-size: 32rpx;
  line-height: 1;
}

.search-shell {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.05);
  border-width: 1px;
  border-style: solid;
  border-color: rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding-left: 20rpx;
  padding-right: 24rpx;
  min-height: 80rpx;
  margin-left: 24rpx;
  margin-right: 24rpx;
}

.search-shell-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
  color: var(--search-muted);
}

.search-input {
  flex: 1;
  min-width: 0;
  font-size: var(--font-sm);
  color: #ffffff;
}

.filter-scroll {
  white-space: nowrap;
  width: 100%;
}

.filter-inner {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
}

.filter-chip {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
  border-radius: 999rpx;
  background-color: rgba(255, 255, 255, 0.06);
  border-width: 1px;
  border-style: solid;
  border-color: rgba(255, 255, 255, 0.1);
}

.filter-chip-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.92);
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.filter-chip-chev {
  margin-left: 12rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
}

.cerca-badge {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background-color: rgba(241, 143, 52, 0.12);
  border-width: 1px;
  border-style: solid;
  border-color: rgba(241, 143, 52, 0.35);
}

.cerca-text {
  margin-left: 8rpx;
  font-size: 22rpx;
  color: #f18f34;
  font-weight: 600;
}

.search-body {
  flex: 1;
  padding: 32rpx;
  box-sizing: border-box;
}

.result-count {
  font-size: var(--font-xs);
  font-weight: 600;
  color: var(--search-muted);
  margin-bottom: var(--space-md);
}

.club-card-outer {
  border-radius: var(--radius-card);
  overflow: hidden;
  border-width: 1px;
  border-style: solid;
  border-color: rgba(255, 255, 255, 0.08);
  margin-bottom: var(--space-md);
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.03));
}

.club-card-inner {
  position: relative;
  padding: 24rpx;
}

.club-fav {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background-color: rgba(0, 0, 0, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.club-fav-text {
  font-size: 24rpx;
  color: #ffffff;
}

.club-row {
  display: flex;
  flex-direction: row;
}

.club-image-col {
  width: 224rpx;
  height: 224rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
}

.club-image {
  width: 100%;
  height: 100%;
}

.club-image-ph {
  width: 100%;
  height: 100%;
  background-color: #1a1a1a;
}

.club-price-badge {
  position: absolute;
  left: 12rpx;
  bottom: 12rpx;
  padding: 8rpx 12rpx;
  border-radius: 12rpx;
  background-color: rgba(0, 0, 0, 0.55);
}

.club-price-main {
  font-size: 26rpx;
  font-weight: 700;
  color: #ffffff;
}

.club-price-sub {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.club-body {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.club-title {
  font-size: var(--font-base);
  font-weight: 600;
  color: #ffffff;
  padding-right: 64rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.club-meta {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 8rpx;
  flex-wrap: nowrap;
}

.club-meta-icon {
  font-size: 24rpx;
  color: var(--search-muted);
  margin-right: 6rpx;
}

.club-meta-dist {
  font-size: var(--font-sm);
  color: var(--search-muted);
}

.club-meta-dot {
  font-size: var(--font-sm);
  color: var(--search-muted);
  margin: 0 8rpx;
}

.club-meta-city {
  font-size: var(--font-sm);
  color: var(--search-muted);
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tags-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background-color: rgba(255, 255, 255, 0.06);
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.tag-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.slots-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.slot-pill {
  padding: 10rpx 18rpx;
  border-radius: 12rpx;
  background-color: rgba(241, 143, 52, 0.12);
  border-width: 1px;
  border-style: solid;
  border-color: rgba(241, 143, 52, 0.35);
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.slot-pill-text {
  font-size: 22rpx;
  color: #f18f34;
  font-weight: 600;
}

.slot-more {
  font-size: 22rpx;
  color: var(--search-muted);
  align-self: center;
}

.skeleton-card {
  height: 280rpx;
  border-radius: var(--radius-card);
  background-color: rgba(255, 255, 255, 0.04);
  margin-bottom: var(--space-md);
}
