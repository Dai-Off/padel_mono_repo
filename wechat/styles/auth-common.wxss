@import './theme.wxss';

.auth-page {
  min-height: 100vh;
  background-color: var(--auth-bg);
  box-sizing: border-box;
  padding-left: 40rpx;
  padding-right: 40rpx;
  padding-bottom: var(--space-xl);
}

.auth-brand-section {
  padding-top: var(--space-xxl);
  padding-bottom: var(--space-lg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.auth-logo {
  width: 200rpx;
  height: 200rpx;
}

.auth-form-section {
  width: 100%;
}

.error-banner {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: var(--space-sm);
  background-color: var(--auth-error-bg);
  border-radius: var(--radius-banner);
  margin-bottom: var(--space-md);
}

.error-banner--info {
  background-color: var(--auth-info-bg);
}

.error-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  background-color: rgba(227, 30, 36, 0.35);
  color: #e31e24;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  line-height: 36rpx;
  flex-shrink: 0;
  margin-right: 12rpx;
  margin-top: 2rpx;
}

.error-banner__text {
  flex: 1;
  margin-left: 0;
  font-size: var(--font-sm);
  line-height: 34rpx;
  color: var(--auth-error);
  font-weight: 500;
}

.error-banner--info .error-banner__text {
  color: var(--auth-info);
}

.auth-input-wrap-outer {
  margin-bottom: var(--space-lg);
}

.auth-input-label {
  font-size: var(--font-sm);
  line-height: 34rpx;
  font-weight: 500;
  color: var(--auth-label);
  margin-bottom: 20rpx;
}

.auth-input-shell {
  display: flex;
  flex-direction: row;
  align-items: center;
  min-height: 88rpx;
  padding: var(--space-md);
  background-color: var(--auth-input-bg);
  border-width: 1px;
  border-style: solid;
  border-color: var(--auth-input-border);
  border-radius: var(--radius-input);
}

.auth-input-shell--error {
  border-color: var(--auth-error);
}

.auth-input-icon {
  margin-right: var(--space-sm);
  font-size: 36rpx;
  color: var(--auth-label);
  line-height: 1;
}

.auth-input-field {
  flex: 1;
  min-width: 0;
  font-size: var(--font-base);
  line-height: 40rpx;
  color: var(--auth-text);
}

.auth-input-placeholder {
  color: #5a5a76;
}

.login-extras-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-start;
  width: 100%;
  margin-bottom: var(--space-sm);
}

.login-extras-col-left {
  flex-shrink: 0;
  margin-right: var(--space-sm);
  min-width: 296rpx;
}

.login-extras-col-right {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: flex-end;
}

.checkbox-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
  border-width: 2rpx;
  border-style: solid;
  border-color: var(--auth-text-secondary);
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox--checked {
  background-color: var(--auth-input-bg);
  border-color: var(--auth-accent);
}

.checkbox-check {
  font-size: 24rpx;
  color: var(--auth-accent);
  font-weight: 700;
}

.checkbox-label {
  font-size: var(--font-sm);
  color: var(--auth-label);
}

.forgot-pressable {
  width: 100%;
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
  padding: 8rpx 0;
}

.login-forgot-label {
  font-size: var(--font-sm);
  line-height: 34rpx;
  font-weight: 500;
  color: var(--auth-accent);
  text-align: right;
}

.auth-button {
  margin-top: var(--space-xl);
  margin-bottom: var(--space-lg);
  padding: var(--space-md) var(--space-xl);
  width: 100% !important;
  border-radius: var(--radius-input);
  border: none;
  background-color: var(--auth-accent) !important;
  box-shadow: 0 16rpx 48rpx var(--auth-accent-shadow);
  display: flex;
  align-items: center;
  justify-content: center;
}

.auth-button::after {
  border: none;
}

.auth-button--disabled {
  opacity: 0.5;
}

.auth-button-inner {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.auth-button-content {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}

.auth-button-text {
  font-size: var(--font-base);
  line-height: 40rpx;
  font-weight: 700;
  color: #ffffff;
  padding-right: 8rpx;
}

.auth-button-icon {
  margin-left: var(--space-md);
  font-size: 36rpx;
  color: #ffffff;
  line-height: 1;
}

.auth-form-link-wrap {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  padding: var(--space-sm) 0;
  width: 100%;
}

.auth-form-link-prompt {
  font-size: var(--font-sm);
  line-height: 34rpx;
  color: var(--auth-text-secondary);
}

.auth-form-link-action {
  font-size: var(--font-sm);
  line-height: 34rpx;
  font-weight: 600;
  color: var(--auth-accent);
  margin-left: 8rpx;
}

.auth-footer-wrap {
  padding: var(--space-lg) var(--space-xs);
  width: 100%;
  box-sizing: border-box;
}

.auth-footer-text {
  font-size: var(--font-xs);
  line-height: 36rpx;
  color: var(--auth-text-secondary);
  text-align: center;
  display: block;
}
