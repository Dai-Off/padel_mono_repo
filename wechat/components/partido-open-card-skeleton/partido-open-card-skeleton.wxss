/* PartidoOpenCardSkeleton — padding 14px, row gap 14px, thumb 112 */
.pos-card {
  border-radius: 24rpx;
  border-width: 1px;
  border-style: solid;
  border-color: rgba(255, 255, 255, 0.08);
  padding: 28rpx;
  background-color: rgba(255, 255, 255, 0.04);
  box-sizing: border-box;
}

.pos-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.pos-thumb {
  width: 224rpx;
  height: 224rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
  background-color: rgba(255, 255, 255, 0.08);
}

.pos-body {
  flex: 1;
  min-width: 0;
  margin-left: 28rpx;
}

.pos-line {
  height: 32rpx;
  border-radius: 8rpx;
  background-color: rgba(255, 255, 255, 0.08);
}

.pos-line-w85 {
  width: 85%;
}

.pos-line-w70 {
  width: 70%;
  margin-top: 16rpx;
}

.pos-badges {
  display: flex;
  flex-direction: row;
  margin-top: 20rpx;
}

.pos-pill {
  width: 112rpx;
  height: 36rpx;
  border-radius: 12rpx;
  background-color: rgba(255, 255, 255, 0.08);
  margin-right: 12rpx;
}

.pos-pill-wide {
  width: 176rpx;
}

.pos-slots {
  display: flex;
  flex-direction: row;
  margin-top: 20rpx;
}

.pos-slot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  background-color: rgba(255, 255, 255, 0.08);
  margin-right: 12rpx;
}
