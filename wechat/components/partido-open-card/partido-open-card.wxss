/* Alineado a mobile-app PartidoOpenCard — 12px pad, 10 gap, 112 thumb, r≈12 → rpx×2 */
.poc-card {
  border-radius: 24rpx;
  overflow: hidden;
  border-width: 1px;
  border-style: solid;
  border-color: rgba(255, 255, 255, 0.08);
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.03));
  position: relative;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.2);
}

.poc-card-border {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  border-radius: 24rpx;
  border-width: 1px;
  border-style: solid;
  border-color: rgba(255, 255, 255, 0.06);
  pointer-events: none;
  z-index: 1;
}

.poc-inner {
  padding: 24rpx;
  position: relative;
  z-index: 2;
}

.poc-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 20rpx;
}

.poc-thumb-wrap {
  width: 224rpx;
  height: 224rpx;
  border-radius: 24rpx;
  overflow: hidden;
  flex-shrink: 0;
  background-color: rgba(0, 0, 0, 0.3);
  position: relative;
}

.poc-thumb {
  width: 100%;
  height: 100%;
}

.poc-thumb-scrim {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to top right, rgba(0, 0, 0, 0.42), transparent);
}

.poc-price-tag {
  position: absolute;
  left: 12rpx;
  bottom: 12rpx;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  background-color: rgba(0, 0, 0, 0.72);
  line-height: 28rpx;
}

.poc-price-main {
  font-size: 24rpx;
  font-weight: 900;
  color: #ffffff;
}

.poc-price-sub {
  font-size: 18rpx;
  color: #d1d5db;
  font-weight: 600;
}

.poc-body {
  flex: 1;
  min-width: 0;
}

.poc-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding-right: 16rpx;
}

.poc-time-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 4rpx;
}

.poc-time-ico {
  font-size: 28rpx;
  color: #6b7280;
  margin-right: 8rpx;
  line-height: 1;
}

.poc-date-txt {
  font-size: 24rpx;
  color: #9ca3af;
  font-weight: 500;
}

.poc-dot {
  font-size: 24rpx;
  color: #4b5563;
  margin: 0 8rpx;
}

.poc-time-txt {
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 500;
}

.poc-badges-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.poc-badge {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-width: 1px;
  border-style: solid;
  border-color: rgba(255, 255, 255, 0.1);
  max-width: 100%;
  box-sizing: border-box;
}

.poc-badge-txt {
  font-size: 18rpx;
  font-weight: 700;
  color: #d1d5db;
  text-transform: uppercase;
}

.poc-slots-scroll {
  width: 100%;
  white-space: nowrap;
}

.poc-slots-row {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  padding-top: 4rpx;
  padding-bottom: 4rpx;
  padding-right: 16rpx;
}

.poc-slot-fill {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #f18f34, #e95f32);
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.poc-slot-ini {
  font-size: 18rpx;
  font-weight: 800;
  color: #ffffff;
}

.poc-slot-free {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  border-width: 1px;
  border-style: dashed;
  border-color: rgba(255, 255, 255, 0.2);
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.poc-slot-plus {
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 600;
}

.poc-libres {
  font-size: 18rpx;
  font-weight: 800;
  color: #f18f34;
  margin-left: 8rpx;
  flex-shrink: 0;
  padding-right: 24rpx;
}
