{
  "expo": {
    "name": "Padel App",
    "slug": "padel-app",
    "scheme": "padelapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "../wechat/images/wematch-logo.png",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-asset",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.wematch.padel",
          "enableGooglePay": false
        }
      ],
      "expo-font",
      "expo-video"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wematch.padel",
      "runtimeVersion": {
        "policy": "appVersion"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "../wechat/images/wematch-logo.png",
        "backgroundColor": "#0F0F0F"
      },
      "softwareKeyboardLayoutMode": "pan",
      "package": "com.anonymous.padelapp",
      "runtimeVersion": "1.0.0"
    },
    "extra": {
      "eas": {
        "projectId": "a3d1a65c-8c6a-40d6-9007-3226cbf37a20"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/a3d1a65c-8c6a-40d6-9007-3226cbf37a20"
    }
  }
}
