{
  "expo": {
    "name": "WeMatch",
    "slug": "padel-app",
    "scheme": "wematch",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/wematch-logo.png",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-asset",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.wematch.padel",
          "enableGooglePay": false
        }
      ],
      "expo-font",
      "expo-video",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "WeMatch usa tu ubicación para buscar partidos, el clima y elegir dónde juegas en tu perfil."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "WeMatch necesita acceso a tus fotos para la foto de perfil y la portada.",
          "cameraPermission": "WeMatch necesita la cámara para hacer tu foto de perfil o portada.",
          "microphonePermission": false
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-localization"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wematch.padel",
      "runtimeVersion": {
        "policy": "appVersion"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/wematch-logo.png",
        "backgroundColor": "#000000"
      },
      "softwareKeyboardLayoutMode": "pan",
      "package": "com.anonymous.padelapp",
      "runtimeVersion": "1.0.0",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "42e3550f-3cc0-46b1-82b6-2306d96ab923"
      }
    },
    "owner": "tradebotg"
  }
}
