{
  "name": "padel-be",
  "version": "1.0.0",
  "description": "Backend para Padel App",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "seed:bookings": "ts-node -r dotenv/config scripts/seed-bookings.ts",
    "jobs:leveling": "ts-node -r dotenv/config scripts/leveling-jobs.ts"
  },
  "keywords": [
    "node",
    "express",
    "typescript",
    "backend",
    "supabase"
  ],
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.56.1",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.0",
    "openskill": "^4.1.1",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.8.4",
    "pg": "^8.20.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18"
  }
}
