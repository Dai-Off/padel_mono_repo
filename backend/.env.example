PORT=3000
FRONTEND_URL=http://localhost:5173

# Web y móvil → misma URL (Supabase Redirect URLs + web-app en dev):
#   http://localhost:5173/reset-password
#   https://padel-fe.fly.dev/reset-password
# PASSWORD_RESET_REDIRECT_URL=

# URL pública del backend (invitaciones torneos, etc.)
# BACKEND_PUBLIC_URL=http://localhost:3000

# Scheme de la app (app.json → expo.scheme). Deep link: {MOBILE_APP_SCHEME}://reset-password
# MOBILE_APP_SCHEME=wematch

# SMTP (Gmail por defecto si no defines SMTP_HOST). Producción con otro proveedor: SMTP_HOST + SMTP_PORT.
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false

# URL exacta de reset en web (opcional). Debe estar en Supabase → Auth → Redirect URLs.
# Por defecto: {FRONTEND_URL}/reset-password
# WEB_PASSWORD_RESET_REDIRECT_URL=https://padel-fe.fly.dev/reset-password

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — tarjeta GET /players/:id/last-peer-feedback-insight (ver docs/peer-feedback-insight.md)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Pase Elite temporada (céntimos, mín. 50). Por defecto en código: 999 (= 9,99 €).
# SEASON_PASS_ELITE_PRICE_CENTS=999

# Stripe: Dashboard > API Keys (clave secreta sk_test_...)
STRIPE_SECRET_KEY=
# Webhook: usa Stripe CLI para local: stripe listen --forward-to localhost:3000/payments/webhook
STRIPE_WEBHOOK_SECRET=
